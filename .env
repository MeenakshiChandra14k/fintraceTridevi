
# ==============================================================================
# LOCAL INFRASTRUCTURE (DOCKER) CONFIGURATION
# ==============================================================================

# Local Kafka Broker Connection (Bypassing Aiven SSL Certs)
KAFKA_SERVICE_URI=localhost:9092

# Topics Configuration (Syncing Gateway & DeepBrain)
KAFKA_TOPIC_TRANSACTIONS=banking_transactions
KAFKA_TOPIC_ALERTS=fraud_alerts

# Performance Tuning 
KAFKA_CONSUMER_GROUP=deepbrain-group-v2
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10

# Local Neo4j Configuration (Matching your Docker compose setup)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j